# ─── Supabase ─────────────────────────────────────────────
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Vite-exposed copies (frontend only)
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT"

# ─── S3 / Supabase Storage ───────────────────────────────
S3_ENDPOINT="https://YOUR_PROJECT.storage.supabase.co/storage/v1/s3"
S3_REGION="ap-southeast-2"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_RESUME_BUCKET="resumes"

# ─── Backend ──────────────────────────────────────────────
VITE_API_BASE_URL="http://localhost:3001"
BACKEND_PORT="3001"
CORS_ORIGIN="*"

# ─── Admin ────────────────────────────────────────────────
SUPER_ADMIN_EMAIL="admin@example.com"
SUPER_ADMIN_PASSWORD=""
SUPER_ADMIN_PASSWORD_ALIASES=""

# ─── AI / Scoring Providers ──────────────────────────────
GITHUB_MODELS_TOKEN=""
GROQ_API_KEY=""
OPENROUTER_API_KEY=""

# ─── Redis (BullMQ) ──────────────────────────────────────
REDIS_URL="redis://127.0.0.1:6379"
